# Ignore ephemeral/large runtime data
backups/
cache/
downloads/
session-env/
sessions/
shell-snapshots/
ide/

# Ignore conversation transcripts and cached artifacts
projects/**/*.jsonl
projects/**/tool-results/
projects/ssh-*/

# Keep memory directories in all projects
!projects/*/memory/
!projects/*/memory/**
.DS_Store
.last-cleanup
