# Global

Host *
ServerAliveInterval 30
ServerAliveCountMax 4
Compression yes # Multiplexing
ControlMaster auto
ControlPath ~/.ssh/cm-%r@%h:%p
ControlPersist 12h # macOS agent + Keychain
AddKeysToAgent yes
UseKeychain yes # Security & Cleanup
GSSAPIAuthentication no
GSSAPIDelegateCredentials no
ForwardX11 no
ForwardX11Trusted no

# GitHub

Host github.com
HostName github.com
User git
IdentityFile ~/.ssh/id_ed25519_github

#DAQTensor

Host daqTensor
HostName 64.106.63.220
User Tensor
IdentityFile ~/.ssh/id_ed25519_daqTensor

#DAQbacon

Host daqbacon
HostName 64.106.63.220
User bacon
IdentityFile ~/.ssh/id_ed25519_daqbacon

# NERSC — key + cert issued by `sshproxy -u tens0r` (short-lived, ~24h)

Host nersc
HostName perlmutter.nersc.gov
User tens0r
IdentityFile ~/.ssh/nersc
CertificateFile ~/.ssh/nersc-cert.pub
IdentitiesOnly yes
